# ============================================================
# Ticketeira - variaveis de ambiente
# Copie para .env e ajuste antes de subir o docker-compose.
# ============================================================

# ---- Postgres ----
POSTGRES_USER=ticketeira
POSTGRES_PASSWORD=ticketeira
POSTGRES_PORT=5432

# ---- RabbitMQ ----
RABBITMQ_USER=ticketeira
RABBITMQ_PASS=ticketeira
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---- JWT ----
# IMPORTANTE: gerar um secret real com >= 32 chars antes de subir.
# Ex.: openssl rand -base64 48
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-de-no-minimo-32-chars
JWT_EXPIRATION_MS=3600000

# ---- Email (MailHog em dev, sandbox local) ----
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
MAIL_FROM=no-reply@pegaticket.local
FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_TTL_MIN=60

# Em PRODUCAO (ex.: Railway com Resend), o user-service usa estas vars no lugar do MailHog:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=2587                     # 587/465/25 sao BLOQUEADOS no Railway; use a porta alternativa 2587
#   SMTP_USER=resend
#   SMTP_PASS=<sua-api-key-resend>     # NUNCA comitar a chave real
#   SMTP_AUTH=true
#   SMTP_STARTTLS=true
#   MAIL_FROM=no-reply@seudominio      # dominio verificado no Resend (sandbox so envia pro dono da conta)
#   FRONTEND_BASE_URL=https://<seu-front>.vercel.app

# ---- Portas dos servicos (host) ----
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
EVENT_SERVICE_PORT=8082
TICKET_SERVICE_PORT=8083
PAYMENT_SERVICE_PORT=8084
FRONTEND_PORT=5173

# ---- Frontend ----
VITE_API_URL=http://localhost:8080

# ---- Rodar local apontando pro Postgres da Railway ----
# (usado pelo docker-compose.railway-db.yml - ver docs/deploy/run-local-vs-railway-db.md)
# RAILWAY_DB_HOST=kodama.proxy.rlwy.net
# RAILWAY_DB_PORT=14441
# RAILWAY_DB_PASS=<senha-do-postgres-railway>
